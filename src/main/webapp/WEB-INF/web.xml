<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_5_0.xsd"
         version="5.0">

    <display-name>필그림시니어랜드</display-name>

    <!-- 앱 초기화 리스너 -->
    <listener>
        <listener-class>com.pilgrimseniorland.listener.AppInitListener</listener-class>
    </listener>

    <!-- 인코딩 필터 (최우선) -->
    <filter>
        <filter-name>EncodingFilter</filter-name>
        <filter-class>com.pilgrimseniorland.filter.EncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>EncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 보안 헤더 필터 (모든 요청) -->
    <filter>
        <filter-name>SecurityHeaderFilter</filter-name>
        <filter-class>com.pilgrimseniorland.filter.SecurityHeaderFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>SecurityHeaderFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- 관리자 인증 필터 -->
    <filter>
        <filter-name>AdminAuthFilter</filter-name>
        <filter-class>com.pilgrimseniorland.filter.AdminAuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AdminAuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>

    <!-- Servlet 매핑 -->
    <servlet>
        <servlet-name>HomeController</servlet-name>
        <servlet-class>com.pilgrimseniorland.controller.HomeController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>HomeController</servlet-name>
        <url-pattern>/</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>PageController</servlet-name>
        <servlet-class>com.pilgrimseniorland.controller.PageController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PageController</servlet-name>
        <url-pattern>/intro/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PageController</servlet-name>
        <url-pattern>/business/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PageController</servlet-name>
        <url-pattern>/signature/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PageController</servlet-name>
        <url-pattern>/residence/*</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>PageController</servlet-name>
        <url-pattern>/privacy</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SupportController</servlet-name>
        <servlet-class>com.pilgrimseniorland.controller.SupportController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SupportController</servlet-name>
        <url-pattern>/support/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ContactController</servlet-name>
        <servlet-class>com.pilgrimseniorland.controller.ContactController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ContactController</servlet-name>
        <url-pattern>/support/contact</url-pattern>
    </servlet-mapping>

    <!-- 관리자 Servlet -->
    <servlet>
        <servlet-name>AdminLoginController</servlet-name>
        <servlet-class>com.pilgrimseniorland.controller.admin.AdminLoginController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminLoginController</servlet-name>
        <url-pattern>/admin/login</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminLoginController</servlet-name>
        <url-pattern>/admin/logout</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminDashboardController</servlet-name>
        <servlet-class>com.pilgrimseniorland.controller.admin.AdminDashboardController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardController</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>AdminDashboardController</servlet-name>
        <url-pattern>/admin</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminNoticeController</servlet-name>
        <servlet-class>com.pilgrimseniorland.controller.admin.AdminNoticeController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminNoticeController</servlet-name>
        <url-pattern>/admin/notice/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminQnaController</servlet-name>
        <servlet-class>com.pilgrimseniorland.controller.admin.AdminQnaController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminQnaController</servlet-name>
        <url-pattern>/admin/qna/*</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AdminContactController</servlet-name>
        <servlet-class>com.pilgrimseniorland.controller.admin.AdminContactController</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminContactController</servlet-name>
        <url-pattern>/admin/contact/*</url-pattern>
    </servlet-mapping>

    <!-- 세션 타임아웃 (30분) -->
    <session-config>
        <session-timeout>30</session-timeout>
    </session-config>

    <!-- 커스텀 오류 페이지 -->
    <error-page>
        <error-code>404</error-code>
        <location>/WEB-INF/jsp/error/404.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/WEB-INF/jsp/error/500.jsp</location>
    </error-page>

    <!-- Welcome 파일 -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>
</web-app>
